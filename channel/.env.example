# Claude Bridge — Channel Server Environment Variables
# Copy this file to .env and fill in your values before running the server manually.
# When started via `bridge start`, these are set automatically by bridge-cli.

# =============================================================================
# REQUIRED
# =============================================================================

# Your Telegram bot token from @BotFather
# Format: <number>:<alphanumeric_string>  e.g. 123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_BOT_TOKEN=your_bot_token_here

# =============================================================================
# OPTIONAL — paths (defaults shown)
# =============================================================================

# Where the message queue database is stored.
# Default: ~/.claude-bridge/messages.db
# MESSAGES_DB_PATH=~/.claude-bridge/messages.db

# Path to the claude-bridge Python source (src/ directory).
# Needed when running the channel server manually outside of bridge-cli.
# The server uses this to locate the on_complete.py stop-hook handler.
# Default: value of $PYTHONPATH, or empty string (relies on installed package)
# BRIDGE_SRC_PATH=/path/to/claude-bridge/src

# Python interpreter path used by the stop-hook relay.
# Default: python3  (whatever is on $PATH)
# PYTHON_PATH=/path/to/python3

# =============================================================================
# NOTES
# =============================================================================
#
# Normal usage (via bridge-cli):
#   bridge-cli setup    — sets TELEGRAM_BOT_TOKEN in ~/.claude-bridge/config.json
#   bridge start        — reads config.json and passes values as env vars
#
# Manual testing (without bridge-cli):
#   cp channel/.env.example channel/.env
#   # Edit channel/.env with your values
#   cd channel && bun run start
#
# The channel server also reads ~/.claude-bridge/config.json at runtime for
# config values not supplied via environment variables.
